# Copy this to .env and fill in your keys.
# .env is gitignored; .env.example is committed.

# LLM provider used by the worker when running precomputed traces.
# Options: anthropic | deepseek  (default: unset = mock brain, fully offline)
GAUNTLET_PROVIDER=deepseek

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Model override (default: claude-sonnet-4-6)
# GAUNTLET_MODEL=claude-sonnet-4-6

# DeepSeek (OpenAI-compatible, base_url https://api.deepseek.com)
DEEPSEEK_API_KEY=sk-...
# Model override (default: deepseek-chat)
# GAUNTLET_MODEL=deepseek-chat

# Legacy flag kept for backwards compat: sets GAUNTLET_PROVIDER=anthropic
# GAUNTLET_USE_ANTHROPIC=1
